{
    "name": "gdal3.js",
    "version": "3.0.0-beta.2",
    "description": "gdal3.js is a port of Gdal to Webassembly and React Native. It allows you to convert raster and vector geospatial data to various formats and coordinate systems.",
    "homepage": "https://gdal3.js.org",
    "repository": "https://github.com/bugra9/gdal3.js.git",
    "license": "LGPL-2.1-or-later",
    "exports": {
        ".": {
            "import": "./index.mjs",
            "require": "./index.cjs"
        },
        "./browser": "./dist/gdal3js-wasm-wasm32-st-release.browser.js",
        "./node": "./dist/gdal3js-wasm-wasm32-st-release.node.js",
        "./wasm": "./dist/gdal3js-wasm-wasm32-st-release.wasm",
        "./data.txt": "./dist/gdal3js-wasm-wasm32-st-release.data.txt"
    },
    "files": [
        "dist",
        "gdal3js.xcframework",
        "src",
        "node.js",
        "cppjs.config.mjs",
        "gdal3js.podspec"
    ],
    "scripts": {
        "build": "cppjs build",
        "build:wasm": "cppjs build -p wasm",
        "build:android": "cppjs build -p android",
        "build:ios": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "test": "pnpm run test:node && pnpm run test:browser",
        "test:node": "mocha",
        "test:browser": "karma start .karma.conf.js"
    },
    "dependencies": {
        "@cpp.js/package-gdal": "^2.0.0-beta.5"
    },
    "devDependencies": {
        "cpp.js": "^2.0.0-beta.6",
        "chai": "^4.3.10",
        "mocha": "^11.0.1",
        "mocha-loader": "^5.1.5",
        "xml-js": "^1.6.11"
    },
    "packageManager": "pnpm@8.15.4+sha1.c85a4305534f76d461407b59277b954bac97b5c4"
}